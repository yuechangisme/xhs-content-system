# 依赖
node_modules/
content/node_modules/

# Claude 配置
.claude/

# 运行时状态（每次运行变化）
state.json
error.log
*.log

# 环境变量与密钥
.env
secrets/
*.cookie
xiaohongshu.json

# 本机私有配置覆盖
config.local.js

# skill 本地配置
local/

# 输出图片
content/**/output/

# 素材与账号信息（不上传）
content/公共素材库/
content/账号信息/

# 清理备份（不上传）
cleanup-backup/

# 选题候选池（运行时状态）
topics/

# 投稿内容资产：运行时生成/发布内容，不进入 Git
content/投稿内容/待制作/**
content/投稿内容/制作中/**
content/投稿内容/待投递/**
content/投稿内容/已投递/**

# 保留目录骨架
!content/投稿内容/待制作/.gitkeep
!content/投稿内容/制作中/.gitkeep
!content/投稿内容/待投递/.gitkeep
!content/投稿内容/已投递/.gitkeep

# 系统文件
.DS_Store
Thumbs.db
